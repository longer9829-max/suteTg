{
  "entities": {
    "UserPublic": {
      "title": "User Public",
      "description": "Publicly visible user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName"]
    },
    "UserPrivate": {
      "title": "User Private",
      "description": "Private user information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single chat message",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "chatId": { "type": "string" }
      },
      "required": ["text", "senderId", "senderName", "createdAt", "chatId"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Chat room metadata",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastMessageVisible": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdBy", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}/public/profile": {
      "schema": "UserPublic",
      "description": "Public user profile"
    },
    "/users/{userId}/private/info": {
      "schema": "UserPrivate",
      "description": "Sensitive user data"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Active chat rooms"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific chat"
    }
  }
}
